<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MahjongPoints.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1120" d:DesignHeight="720"
        x:Class="MahjongPoints.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="MahjongPoints"
        Width="1120"
        Height="720"
        MinWidth="980"
        MinHeight="620">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Border.tile-card">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.tile-card">
            <Setter Property="BorderBrush" Value="#2E90FA"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="16" RowSpacing="12">
        <!--一般作为一个父控件，它可以给子控件控制位置，它DockPanel可以放四周-->
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                <Button x:Name="SelectImageButton"
                        Click="SelectImageButton_OnClick"
                        Padding="16,8"
                        Content="选择图片"/>
                <Button x:Name="LoadClipboardImageButton"
                        Click="LoadClipboardImageButton_OnClick"
                        Padding="16,8"
                        Content="从剪贴板加载"/>
                <TextBlock Text="{Binding SelectedFileName}"
                           VerticalAlignment="Center"
                           Foreground="#444"/>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       TextWrapping="Wrap"
                       Foreground="#555"/>
        </DockPanel>

        <!--定义两列，第一列占3*，第二列占2*，两列边距设置为16-->
        <Grid Grid.Row="1" ColumnDefinitions="3*,2*" ColumnSpacing="16">
            <Grid RowDefinitions="100,*" RowSpacing="12">
                <Border BorderBrush="#D0D5DD"
                        BorderThickness="3"
                        Background="#F7F8FA"
                        CornerRadius="8"
                        Padding="8"
                        Height="100">
                    <Image Source="{Binding PreviewImage}"
                           Stretch="Uniform"/>
                </Border>

                <Border Grid.Row="1"
                        BorderBrush="#D0D5DD"
                        BorderThickness="1"
                        Background="#F7F8FA"
                        CornerRadius="4"
                        Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch">
                    <Grid>
                <StackPanel Spacing="8"
                            IsVisible="{Binding IsWinningTileMode}">
                    <TextBlock Text="识别出的 14 张胡牌"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <ListBox ItemsSource="{Binding RecognizedTiles}"
                             SelectedItem="{Binding ScoringContext.WinningTile, Mode=TwoWay}"
                             SelectionMode="Single"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="tile-card"
                                        Width="86"
                                        Height="108">
                                    <Image Source="{Binding TileImage}"
                                           Stretch="Uniform"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel Spacing="8"
                            IsVisible="{Binding IsTenpaiMode}">
                    <TextBlock Text="叫听牌"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <ListBox ItemsSource="{Binding TenpaiTiles}"
                             SelectedItem="{Binding SelectedTenpaiTile, Mode=TwoWay}"
                             SelectionMode="Single"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="tile-card"
                                        Width="86"
                                        Height="108">
                                    <Image Source="{Binding TileImage}"
                                           Stretch="Uniform"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel Spacing="8"
                            IsVisible="{Binding IsDiscardTenpaiMode}">
                    <TextBlock Text="打出后可听"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <ItemsControl ItemsSource="{Binding TenpaiDiscardOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="6" Margin="0,0,0,10">
                                        <TextBlock Text="{Binding DiscardText}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                        <ItemsControl ItemsSource="{Binding WinningOptions}"
                                                      MinHeight="116">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Classes="tile-card"
                                                            BorderBrush="{Binding SelectionBorderBrush}"
                                                            BorderThickness="{Binding SelectionBorderThickness}"
                                                            Width="86"
                                                            Height="108"
                                                            MinHeight="108"
                                                            PointerPressed="TenpaiDiscardWinningOption_OnPointerPressed">
                                                        <Image Source="{Binding WinningTile.TileImage}"
                                                               MinHeight="92"
                                                               Stretch="Uniform"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                    </Grid>
                </ScrollViewer>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Text="麻将算点"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <Border BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            Background="White"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding ScoreSummary}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding WinningTileText}"
                                       Foreground="#027A48"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding WinningShape}"
                                       Foreground="#555"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            Background="White"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="算点选项"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="立一自"
                                        Padding="12,6"
                                        Command="{Binding SelectRiichiIppatsuTsumoCommand}"/>
                                <Button Content="立一"
                                        Padding="12,6"
                                        Command="{Binding SelectRiichiIppatsuCommand}"/>
                                <Button Content="立自"
                                        Padding="12,6"
                                        Command="{Binding SelectRiichiTsumoCommand}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <StackPanel Width="120" Spacing="4">
                                    <TextBlock Text="自风"
                                               Foreground="#555"
                                               FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding WindOptions}"
                                              SelectedItem="{Binding SelectedSelfWindOption, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Width="120" Spacing="4">
                                    <TextBlock Text="场风"
                                               Foreground="#555"
                                               FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding WindOptions}"
                                              SelectedItem="{Binding SelectedRoundWindOption, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Width="120" Spacing="4">
                                    <TextBlock Text="宝牌"
                                               Foreground="#555"
                                               FontSize="12"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Content="-"
                                                Width="32"
                                                Command="{Binding DecrementDoraCountCommand}"/>
                                        <TextBlock Text="{Binding ScoringContext.DoraCount}"
                                                   Width="32"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="+"
                                                Width="32"
                                                Command="{Binding IncrementDoraCountCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ScoringOptionItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox MinWidth="120"
                                                  Margin="0,0,12,8"
                                                  Content="{Binding DisplayName}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEnabled}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
