<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MahjongPoints.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1120" d:DesignHeight="720"
        x:Class="MahjongPoints.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="MahjongPoints"
        Width="1120"
        Height="720"
        MinWidth="980"
        MinHeight="620">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="16" RowSpacing="12">
        <!--一般作为一个父控件，它可以给子控件控制位置，它DockPanel可以放四周-->
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                <Button x:Name="SelectImageButton"
                        Click="SelectImageButton_OnClick"
                        Padding="16,8"
                        Content="选择图片"/>
                <TextBlock Text="{Binding SelectedFileName}"
                           VerticalAlignment="Center"
                           Foreground="#444"/>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       TextWrapping="Wrap"
                       Foreground="#555"/>
        </DockPanel>

        <!--定义两列，第一列占3*，第二列占2*，两列边距设置为16-->
        <Grid Grid.Row="1" ColumnDefinitions="3*,2*" ColumnSpacing="16">
            <Border BorderBrush="#D0D5DD"
                    BorderThickness="3"
                    Background="#F7F8FA"
                    CornerRadius="8"
                    Padding="8">
                <Image Source="{Binding PreviewImage}"
                       Stretch="Uniform"/>
            </Border>

            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Text="算点 Demo"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding RecognitionSummary}"
                                   Foreground="#555"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedImagePath}"
                                   Foreground="#667085"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            Background="White"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding ScoreSummary}"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding WinningTileText}"
                                       Foreground="#027A48"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding WinningShape}"
                                       Foreground="#555"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ScoringMessage}"
                                       Foreground="#667085"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="8">
                        <TextBlock Text="识别出的 14 张胡牌"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding RecognizedTiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="86"
                                            Margin="0,0,8,8"
                                            Padding="8"
                                            BorderBrush="#D0D5DD"
                                            BorderThickness="1"
                                            Background="White"
                                            CornerRadius="4">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Code}"
                                                       FontSize="12"
                                                       Foreground="#667085"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ConfidenceText}"
                                                       FontSize="12"
                                                       Foreground="#027A48"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            Background="White"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="算点选项"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding ScoringOptionItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox MinWidth="120"
                                                  Margin="0,0,12,8"
                                                  Content="{Binding DisplayName}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="8">
                        <TextBlock Text="番符明细"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding ScoreItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            BorderBrush="#D0D5DD"
                                            BorderThickness="1"
                                            Background="White"
                                            CornerRadius="4">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="#555"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
