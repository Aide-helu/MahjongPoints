<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MahjongPoints.Android.Views.MainView">
  <Grid RowDefinitions="Auto,*" Margin="20" RowSpacing="16">
    <TextBlock Text="MahjongPoints"
               FontSize="24"
               FontWeight="SemiBold"/>
    <TextBlock Grid.Row="1"
               Text="Android port scaffold"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
  </Grid>
</UserControl>
