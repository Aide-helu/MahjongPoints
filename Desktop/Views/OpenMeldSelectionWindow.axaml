<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MahjongPoints.Views.OpenMeldSelectionWindow"
        Title="选择副露面子"
        Width="520"
        Height="420"
        MinWidth="420"
        MinHeight="360"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16" RowSpacing="12">
        <TextBlock Text="{Binding Message}"
                   TextWrapping="Wrap"
                   Foreground="#555"/>

        <Border Grid.Row="1"
                BorderBrush="#D0D5DD"
                BorderThickness="1"
                CornerRadius="4"
                Background="White"
                Padding="10">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding MeldOptions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayText}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="取消"
                    MinWidth="80"
                    Click="CancelButton_OnClick"/>
            <Button Content="确认"
                    MinWidth="80"
                    IsEnabled="{Binding CanConfirm}"
                    Click="ConfirmButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
