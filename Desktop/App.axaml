<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MahjongPoints.App"
             xmlns:local="using:MahjongPoints"
             RequestedThemeVariant="Light">
             <!-- "Default" follows the system theme. Use "Light" to keep runtime aligned with the designer preview. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
